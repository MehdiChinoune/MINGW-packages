apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying ${_patch}"
    patch -Nbp1 -i "${srcdir}/${_patch}"
  done
}

prepare() {
  cd "${srcdir}/gmsh-${pkgver}-source"

  apply_patch_with_msg \
    0001-fix-link-lib-name.patch \
    0002-fix-dynamic-linking.patch \
    0003-fix-cmake-config-install-dir.patch \
    0004-requires-std-cxx-17.patch \
    dcae93a0.patch \
    0006-fix-build-with-OCCT-8.0.patch \
    0007-fix-build-with-OCCT-8.0_2.patch \
    0008-fix-build-with-OCCT-8.0_3.patch \
    0009-fix-build-with-gcc-16.patch

  if [[ ${CARCH} == aarch64 ]]; then
    apply_patch_with_msg \
      0005-aarch64-image-base.patch

    # The icons are only provided in binary format for 32 bits
    # and 64bits without source code
    msg2 "Creating aarch64 icon resource binary"

    echo "#define IDI_ICON 101" >> src/fltk/Win64Icon.h
    echo "#include \"Win64Icon.h\"" >> src/fltk/Win64Icon.rc
    echo "IDI_ICON ICON \"Win64Icon.ico\"" >> src/fltk/Win64Icon.rc

   "${MINGW_PREFIX}"/bin/windres  \
    -i "src/fltk/Win64Icon.rc" \
    -o "src/fltk/Win64Icon.res"
  fi
}

build() {
  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    "${MINGW_PREFIX}"/bin/cmake \
      -GNinja \
      -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
      -DCMAKE_CXX_STANDARD=17 \
      "${_extra_config[@]}" \
      -DENABLE_BUILD_DYNAMIC=ON \
      -DENABLE_BUILD_SHARED=ON \
      -DENABLE_CAIRO=ON \
      -DENABLE_CGNS=ON \
      -DENABLE_OCC=ON \
      -DENABLE_OPENMP=ON \
      -DENABLE_PETSC=ON \
      -DENABLE_SLEPC=ON \
      -DENABLE_TINYXML2=ON \
      -DGMSH_RELEASE=ON \
      -DENABLE_SYSTEM_CONTRIB=ON \
      -DENABLE_TESTS=OFF \
      -S gmsh-${pkgver}-source \
      -B build-${MSYSTEM}

  "${MINGW_PREFIX}"/bin/cmake --build build-${MSYSTEM}
}

check () {
  cd "${srcdir}/build-${MSYSTEM}"
  "${MINGW_PREFIX}"/bin/ctest .
}

package() {
  DESTDIR="${pkgdir}" "${MINGW_PREFIX}"/bin/cmake --install build-${MSYSTEM}

  mv "${pkgdir}${MINGW_PREFIX}"/lib/*.dll "${pkgdir}${MINGW_PREFIX}"/bin/
}
