_realname=biber
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=2.21
pkgrel=1
pkgdesc="Backend processor for BibLaTeX. (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url='https://github.com/plk/biber'
license=('spdx:Artistic-2.0')
depends=("${MINGW_PACKAGE_PREFIX}-perl"
         "${MINGW_PACKAGE_PREFIX}-perl-autovivification"
         "${MINGW_PACKAGE_PREFIX}-perl-business-isbn"
         "${MINGW_PACKAGE_PREFIX}-perl-business-ismn"
         "${MINGW_PACKAGE_PREFIX}-perl-business-issn"
         "${MINGW_PACKAGE_PREFIX}-perl-class-accessor"
         "${MINGW_PACKAGE_PREFIX}-perl-data-compare"
         "${MINGW_PACKAGE_PREFIX}-perl-data-dump"
         "${MINGW_PACKAGE_PREFIX}-perl-data-uniqid"
         "${MINGW_PACKAGE_PREFIX}-perl-datetime-calendar-julian"
         "${MINGW_PACKAGE_PREFIX}-perl-datetime-format-builder"
         "${MINGW_PACKAGE_PREFIX}-perl-file-slurper"
         "${MINGW_PACKAGE_PREFIX}-perl-io-string"
         "${MINGW_PACKAGE_PREFIX}-perl-ipc-run3"
         #"${MINGW_PACKAGE_PREFIX}-perl-lingua-translit"
         "${MINGW_PACKAGE_PREFIX}-perl-list-allutils"
         #"${MINGW_PACKAGE_PREFIX}-perl-log-log4perl"
         #"${MINGW_PACKAGE_PREFIX}-perl-lwp-protocol-https"
         "${MINGW_PACKAGE_PREFIX}-perl-mozilla-ca")
         #"${MINGW_PACKAGE_PREFIX}-perl-parse-recdescent"
         #"${MINGW_PACKAGE_PREFIX}-perl-perlio-utf8-strict"
         #"${MINGW_PACKAGE_PREFIX}-perl-regexp-common"
         #"${MINGW_PACKAGE_PREFIX}-perl-sort-key"
         #"${MINGW_PACKAGE_PREFIX}-perl-text-bibtex"
         #"${MINGW_PACKAGE_PREFIX}-perl-csv"
         #"${MINGW_PACKAGE_PREFIX}-perl-roman"
         #"${MINGW_PACKAGE_PREFIX}-perl-unicode-linebreak"
         #"${MINGW_PACKAGE_PREFIX}-perl-xml-libxml-simple"
         #"${MINGW_PACKAGE_PREFIX}-perl-xml-libxslt"
         #"${MINGW_PACKAGE_PREFIX}-perl-xml-writer")
makedepends=("${MINGW_PACKAGE_PREFIX}-perl-module-build"
             "${MINGW_PACKAGE_PREFIX}-perl-test-differences")
source=("https://github.com/plk/biber/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz")
sha256sums=('2652cf3ae0abff5fb233aa77f18e70014cc2c70b94a8693c099a3cad9bbb4b20')

prepare() {
  cd "${_realname}-${pkgver}"

  # patch -p1 -i ../0001-A-fix.patch
}

build() {
  cp -r ${_realname}-${pkgver} build-${MSYSTEM}
  cd "build-${MSYSTEM}"

  perl Build.PL
  ./Build
}

package() {
  cd "build-${MSYSTEM}"
  MSYS2_ARG_CONV_EXCL="--prefix=" \
  ./Build install --destdir="${pkgdir}" --prefix=${MINGW_PREFIX}
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENSE \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}
