noextract=("${_realname}-v${pkgver}.tar.gz")

get_pyver () {
  python -c 'import sys; print(str(sys.version_info[0]) + "." + str(sys.version_info[1]))'
}

prepare() {
  echo "Extracting ${_realname}-v${pkgver}.tar.gz ..."
  tar -xzf ${_realname}-v${pkgver}.tar.gz || true

  cd "${srcdir}/${_realname}-v${pkgver}"

  # Fix cmake prefix path (FS#78665)
  patch -Np1 -i "${srcdir}"/fix_cmake_prefix_path.patch

  # https://bugs.archlinux.org/task/64981
  patch -Np1 -i "${srcdir}"/fix_include_system.patch

  # Use system libuv
  patch -Np1 -i "${srcdir}"/use-system-libuv.patch

  # Fix building against glog 0.6
  patch -Np1 -i "${srcdir}/87773.patch"

  # Fix building against glog 0.7
  patch -p1 -i "${srcdir}/glog-0.7.patch"

  # Disable -Werror
  patch -Np1 -i "${srcdir}/disable-werror1.patch"
  patch -Np1 -i "${srcdir}/disable-werror2.patch"
  patch -Np1 -i "${srcdir}/disable-werror4.patch"

  patch -Np1 -i "${srcdir}/pytorch-missing-iostream.patch"

  # cd third_party/XNNPACK
  # git cherry-pick -X theirs --no-commit 5f23827e66cca435fa400b6e221892ac95af0079
  # cd ../..
}

# Common build configuration, called in all package() functions.
_prepare() {
  export VERBOSE=1
  export PYTORCH_BUILD_VERSION="${pkgver}"
  export PYTORCH_BUILD_NUMBER=1

  # Check tools/setup_helpers/cmake.py, setup.py and CMakeLists.txt for a list of flags that can be set via env vars.
  export ATEN_NO_TEST=ON  # do not build ATen tests
  export USE_MKLDNN=OFF
  export BUILD_CUSTOM_PROTOBUF=OFF
  export USE_FFMPEG=ON
  export USE_GFLAGS=ON
  export USE_GLOG=ON
  export USE_OBSERVERS=ON
  export USE_OPENCV=ON
  export USE_VULKAN=ON
  # export USE_SYSTEM_LIBS=ON  # experimental, not all libs present in repos
  export USE_SYSTEM_PYBIND11=ON
  export USE_SYSTEM_EIGEN_INSTALL=ON

  export USE_CUDA=0
  export USE_CUDNN=0
  export USE_ROCM=0
}

build() {
  cp -r "${_realname}-v${pkgver}" "python-build-${MSYSTEM}" && cd "python-build-${MSYSTEM}"

  if [[ ${CARCH} == x86_64 ]]; then
    echo "add_definitions(-march=x86-64-v3)" >> cmake/MiscCheck.cmake
  fi

  # this horrible hack is necessary because the current release
  # ships inconsistent CMake which tries to build objects before
  # their dependencies, build twice when dependencies are available
  ${MINGW_PREFIX}/bin/python -m build --wheel --skip-dependency-check --no-isolation || \
  ${MINGW_PREFIX}/bin/python -m build --wheel --skip-dependency-check --no-isolation
}

package() {
  cd "${srcdir}/python-build-${MSYSTEM}"

  # Prevent setup.py from re-running CMake and rebuilding
  sed -e 's/RUN_BUILD_DEPS = True/RUN_BUILD_DEPS = False/g' -i setup.py

  MSYS2_ARG_CONV_EXCL="--prefix=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${pkgdir}" dist/*.whl

  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/${pkgname}/LICENSE"

  pytorchpath="${MINGW_PREFIX}/lib/python$(get_pyver)/site-packages/torch"

  # put CMake files in correct place
  mv "${pkgdir}/${pytorchpath}/share/cmake" "${pkgdir}${MINGW_PREFIX}/lib/cmake"

  # put C++ API in correct place
  mv "${pkgdir}"${pytorchpath}/include "${pkgdir}${MINGW_PREFIX}/include"

  for _lib in "${pkgdir}"${pytorchpath}/lib/*.dll.a; do
    cp "${_lib}" "${pkgdir}"${MINGW_PREFIX}/lib/
  done

  install -d "${pkgdir}"${MINGW_PREFIX}/bin
  for _lib in "${pkgdir}"${pytorchpath}/lib/*.dll; do
    cp "${_lib}" "${pkgdir}"${MINGW_PREFIX}/bin/
  done

  # Clean up duplicates with Arch packages
  rm "${pkgdir}"${MINGW_PREFIX}/include/*.h
}
