apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying $_patch"
    patch -Np1 -i "${srcdir}/$_patch"
  done
}

prepare() {
  cd "${_realname}-${pkgver}"

  apply_patch_with_msg \
    001-use-system-onednn.patch \
    002-use-system-flatbuffers.patch \
    003-use-system-nlohmann-json.patch \
    004-use-system-microsoft-gsl.patch \
    005-use-system-pybind11.patch \
    006-no-winmeta_h-on-mingw-w64.patch \
    007-dont-use-msvc-flags-on-mingw-w64.patch \
    008-include-missing-header-on-windows.patch
}

build() {
  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  if [[ ${CARCH} == x86_64 ]]; then
    _extra_config+=("-Donnxruntime_USE_AVX2=ON")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    cmake -Wno-dev \
    --compile-no-warning-as-error \
    --log-level=VERBOSE \
    -GNinja \
    -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
    -DCMAKE_POLICY_DEFAULT_CMP0168=NEW \
    -Donnxruntime_ENABLE_PYTHON=ON \
    -Donnxruntime_BUILD_SHARED_LIB=ON \
    -Donnxruntime_BUILD_UNIT_TESTS=OFF \
    -DBUILD_TESTING=OFF \
    -Donnxruntime_ENABLE_TRAINING=ON \
    -Donnxruntime_ENABLE_LAZY_TENSOR=OFF \
    -Donnxruntime_USE_DNNL=ON \
    -Donnxruntime_ENABLE_CPUINFO=OFF \
    -Donnxruntime_ENABLE_ATEN=OFF \
    -DPython_EXECUTABLE=${MINGW_PREFIX}/bin/python \
    -S ${_realname}-${pkgver}/cmake \
    -B build-${MSYSTEM}

  cmake --build build-${MSYSTEM}

  cp ${_realname}-${pkgver}/setup.py "build-${MSYSTEM}"/
  cp ${_realname}-${pkgver}/docs/python/README.rst "build-${MSYSTEM}"/docs/python/README.rst

  python -m build --wheel --skip-dependency-check --no-isolation
}

package_onnxruntime() {
  depends=("${MINGW_PACKAGE_PREFIX}-abseil-cpp"
           "${MINGW_PACKAGE_PREFIX}-boost-libs"
           "${MINGW_PACKAGE_PREFIX}-onednn"
           "${MINGW_PACKAGE_PREFIX}-onnx"
           "${MINGW_PACKAGE_PREFIX}-protobuf"
           "${MINGW_PACKAGE_PREFIX}-re2")

  DESTDIR="${pkgdir}" cmake --install build-${MSYSTEM}

  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENSE \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/python-${_realname}/LICENSE
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/ThirdPartyNotices.txt \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/python-${_realname}/ThirdPartyNotices.txt
}

package_python-onnxruntime() {
  depends=("${MINGW_PACKAGE_PREFIX}-python"
           "${MINGW_PACKAGE_PREFIX}-python-coloredlogs"
           "${MINGW_PACKAGE_PREFIX}-python-numpy"
           "${MINGW_PACKAGE_PREFIX}-python-packaging"
           "${MINGW_PACKAGE_PREFIX}-python-protobuf"
           "${MINGW_PACKAGE_PREFIX}-python-sympy"
           "${MINGW_PACKAGE_PREFIX}-onnxruntime")
  options=('!strip')

  cd "build-${MSYSTEM}"

  MSYS2_ARG_CONV_EXCL="--prefix=" \
    python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${pkgdir}" dist/*.whl

  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENSE \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/python-${_realname}/LICENSE
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/ThirdPartyNotices.txt \
    "${pkgdir}"${MINGW_PREFIX}/share/licenses/python-${_realname}/ThirdPartyNotices.txt
}

# template start; name=mingw-w64-splitpkg-wrappers; version=1.0;
# vim: set ft=bash :

# generate wrappers
for _name in "${pkgname[@]}"; do
  _short="package_${_name#${MINGW_PACKAGE_PREFIX}-}"
  _func="$(declare -f "${_short}")"
  eval "${_func/#${_short}/package_${_name}}"
done
# template end;
