             "${MINGW_PACKAGE_PREFIX}-python-installer"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools"
             "${MINGW_PACKAGE_PREFIX}-pybind11"
             "${MINGW_PACKAGE_PREFIX}-python-coloredlogs"
             "${MINGW_PACKAGE_PREFIX}-python-numpy"
             "${MINGW_PACKAGE_PREFIX}-python-packaging"
             "${MINGW_PACKAGE_PREFIX}-python-protobuf"
             "${MINGW_PACKAGE_PREFIX}-python-sympy")
source=("https://github.com/microsoft/onnxruntime/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        001-use-system-onednn.patch
        002-use-system-flatbuffers.patch
        003-use-system-nlohmann-json.patch
        004-use-system-microsoft-gsl.patch
        005-use-system-pybind11.patch
        006-no-winmeta_h-on-mingw-w64.patch
        007-dont-use-msvc-flags-on-mingw-w64.patch
        008-include-missing-header-on-windows.patch)
