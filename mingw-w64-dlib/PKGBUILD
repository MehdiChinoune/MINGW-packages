# Maintainer: Peter Budai <peterbudai@hotmail.com>

_realname=dlib
pkgbase="mingw-w64-${_realname}"
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}" "${MINGW_PACKAGE_PREFIX}-python-${_realname}")
pkgver=19.24.6
pkgrel=1
pkgdesc="A toolkit for making real world machine learning and data analysis applications in C++ (mingw-w64)"
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='http://dlib.net/'
msys2_repository_url='https://github.com/davisking/dlib/'
msys2_references=(
  'pypi: dlib'
)
license=('spdx:BSL-1.0')
depends=("${MINGW_PACKAGE_PREFIX}-giflib"
         "${MINGW_PACKAGE_PREFIX}-ffmpeg"
         #"${MINGW_PACKAGE_PREFIX}-fftw"
         "${MINGW_PACKAGE_PREFIX}-libjxl"
         "${MINGW_PACKAGE_PREFIX}-libpng"
         "${MINGW_PACKAGE_PREFIX}-libjpeg-turbo"
         "${MINGW_PACKAGE_PREFIX}-libwebp"
         "${MINGW_PACKAGE_PREFIX}-openblas"
         "${MINGW_PACKAGE_PREFIX}-sqlite3")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-python-build"
             "${MINGW_PACKAGE_PREFIX}-python-installer"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools")
source=("https://github.com/davisking/${_realname}/archive/v${pkgver}/${_realname}-${pkgver}.tar.gz"
        "001-python-binding.patch"
        "002-fix-build-with-clang-19.patch")
sha256sums=('22513c353ec9c153300c394050c96ca9d088e02966ac0f639e989e50318c82d6'
            '7e4db50820feeffc2a13e0463bc598e572881fdebd96bb6b567a40049640a824'
            '63d9bccc6b3dcf404ab8f12fa5867f400eb641ad97609a0fafce764cbc71b613')

prepare() {
  cd "${srcdir}/${_realname}-${pkgver}"

  patch -Np1 -i "${srcdir}/001-python-binding.patch"
  patch -Np1 -i "${srcdir}/002-fix-build-with-clang-19.patch"

  cd "${srcdir}"
  cp -r "${_realname}-${pkgver}" "python-build-${MSYSTEM}"
}

build() {
  mkdir -p "${srcdir}"/build-${MSYSTEM} && cd "${srcdir}"/build-${MSYSTEM}

  declare -a _extra_config
  if check_option "debug" "n"; then
    _extra_config+=("-DCMAKE_BUILD_TYPE=Release")
  else
    _extra_config+=("-DCMAKE_BUILD_TYPE=Debug")
  fi

  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
    ${MINGW_PREFIX}/bin/cmake.exe \
      -G'Ninja' \
      -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
      "${_extra_config[@]}" \
      -DUSE_AVX_INSTRUCTIONS=ON \
      -DDLIB_ISO_CPP_ONLY=OFF \
      -DDLIB_IN_PROJECT_BUILD=OFF \
      -DDLIB_USE_CUDA=OFF \
      -DDLIB_GIF_SUPPORT=ON \
      -DDLIB_JPEG_SUPPORT=ON \
      -DDLIB_JXL_SUPPORT=ON \
      -DDLIB_PNG_SUPPORT=ON \
      -DDLIB_WEBP_SUPPORT=ON \
      -DDLIB_LINK_WITH_SQLITE3=ON \
      -DDLIB_USE_BLAS=ON \
      -DDLIB_USE_FFMPEG=ON \
      -DDLIB_USE_LAPACK=ON \
      -DBUILD_SHARED_LIBS=ON \
      -DBLA_VENDOR=OpenBLAS \
      ../${_realname}-${pkgver}

  ${MINGW_PREFIX}/bin/cmake.exe --build .

  msg "Python build for ${MSYSTEM}"
  cd "${srcdir}/python-build-${MSYSTEM}"
  ${MINGW_PREFIX}/bin/python -m build --wheel --skip-dependency-check --no-isolation \
    -C-GNinja \
    -C"--set CMAKE_INSTALL_PREFIX=${MINGW_PREFIX}" \
    -C"--set USE_AVX_INSTRUCTIONS=ON" \
    -C"--set DLIB_ISO_CPP_ONLY=OFF" \
    -C"--set DLIB_IN_PROJECT_BUILD=ON" \
    -C"--set DLIB_USE_CUDA=OFF" \
    -C"--set DLIB_GIF_SUPPORT=ON" \
    -C"--set DLIB_JPEG_SUPPORT=ON" \
    -C"--set DLIB_JXL_SUPPORT=ON" \
    -C"--set DLIB_PNG_SUPPORT=ON" \
    -C"--set DLIB_WEBP_SUPPORT=ON" \
    -C"--set DLIB_LINK_WITH_SQLITE3=ON" \
    -C"--set DLIB_USE_BLAS=ON" \
    -C"--set DLIB_USE_FFMPEG=ON" \
    -C"--set DLIB_USE_LAPACK=ON" \
    -C"--set BLA_VENDOR=OpenBLAS"
}

package_dlib() {
  optdepends=("${MINGW_PACKAGE_PREFIX}-python-dlib")

  cd "${srcdir}"/build-${MSYSTEM}
  DESTDIR="${pkgdir}" ${MINGW_PREFIX}/bin/cmake.exe --install ./

  # Remove hard coded library path from cmake files
  local PREFIX_DEPS=$(cygpath -am ${MINGW_PREFIX})
  for pcfile in  "${pkgdir}${MINGW_PREFIX}"/lib/pkgconfig/*.pc; do
    sed -s "s|${PREFIX_DEPS}|${MINGW_PREFIX}|g" -i "${pcfile}"
  done
  sed -s "s|${PREFIX_DEPS}/include||g" \
    -i "${pkgdir}"${MINGW_PREFIX}/lib/cmake/dlib/dlibConfig.cmake
  sed -s -e "s|${PREFIX_DEPS}/lib/||g" -e "s|${PREFIX_DEPS}/include||g" \
    -i "${pkgdir}"${MINGW_PREFIX}/lib/cmake/dlib/dlib.cmake
}

package_python-dlib() {
  depends=("${MINGW_PACKAGE_PREFIX}-dlib"
           "${MINGW_PACKAGE_PREFIX}-python")
  optdepends=("${MINGW_PACKAGE_PREFIX}-python-numpy: Python interface")

  cd "${srcdir}/python-build-${MSYSTEM}"
  MSYS2_ARG_CONV_EXCL="--prefix=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${pkgdir}" dist/*.whl
}

# template start; name=mingw-w64-splitpkg-wrappers; version=1.0;
# vim: set ft=bash :

# generate wrappers
for _name in "${pkgname[@]}"; do
  _short="package_${_name#${MINGW_PACKAGE_PREFIX}-}"
  _func="$(declare -f "${_short}")"
  eval "${_func/#${_short}/package_${_name}}"
done
# template end;
