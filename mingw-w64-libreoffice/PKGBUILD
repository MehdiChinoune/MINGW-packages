prepare() {
  echo "Extracting ${_realname}-${pkgver}.tar.xz ..."
  tar -xJf ${_realname}-${pkgver}.tar.xz || true

  # move external sources into place
  mkdir -p "${srcdir}"/ext_sources
  for source in "${noextrac[@]:1}"; do
    cp "${srcdir}"/$source "${srcdir}"/ext_sources/
  done

  cd "${_realname}-${pkgver}"
  patch -p1 -i "${srcdir}"/001-fix-configure.patch

  ACLOCAL="aclocal -I${srcdir}/${_realname}-${pkgver}/m4" \
  autoreconf -fiv -I "${srcdir}"/${_realname}-${pkgver}
}

build() {
  mkdir -p "${srcdir}/build-${MSYSTEM}" && cd "${srcdir}/build-${MSYSTEM}"

  SYSTEM_GENCCODE=${MINGW_PREFIX}/sbin/genccode.exe \
  SYSTEM_GENCMN=${MINGW_PREFIX}/sbin/gencmn.exe \
  ../"${_realname}-${pkgver}"/autogen.sh \
    --prefix="${MINGW_PREFIX}" \
    --with-parallelism=${MAKEFLAGS/-j/} \
    --with-external-tar="${srcdir}/ext_sources" \
    --disable-fetch-external \
    --with-system-libs \
    --with-boost-date-time=boost_date_time-mt \
    --with-boost-filesystem=boost_filesystem-mt \
    --with-boost-iostreams=boost_iostreams-mt \
    --with-boost-locale=boost_locale-mt \
    --with-boost-system=boost_system-mt \
    --enable-qt5 \
    --enable-qt6 \
    --enable-gtk3 \
    --enable-gtk4 \
    --without-java \
    --without-fonts

  make
}

check() {
  cd "${srcdir}/build-${MSYSTEM}"

  make check
}

package() {
  cd "${srcdir}/build-${MSYSTEM}"

  make install DESTDIR="${pkgdir}"

  install -Dm644 "${srcdir}/${_realname}-${pkgver}/COPYING.MPL" "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
