--- a/onnx/common/scoped_resource.h
+++ b/onnx/common/scoped_resource.h
@@ -54,9 +54,12 @@
 
 #ifdef _WIN32
 inline void close_handle(HANDLE h) {
-  CloseHandle(h);
+  // Windows APIs may use either nullptr or INVALID_HANDLE_VALUE (-1) as invalid.
+  if (h && h != INVALID_HANDLE_VALUE) {
+    CloseHandle(h);
+  }
 }
-using ScopedHandle = ScopedResource<INVALID_HANDLE_VALUE, close_handle>;
+using ScopedHandle = ScopedResource<static_cast<HANDLE>(nullptr), close_handle>;
 #endif
 
